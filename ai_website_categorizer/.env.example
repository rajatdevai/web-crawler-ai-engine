# App
APP_NAME=AI_Website_Categorizer
APP_ENV=development # development | staging | production
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ai_crawler

# Redis
REDIS_URL=redis://localhost:6379/0

# Crawler
MAX_CONCURRENT_WORKERS=5
REQUEST_TIMEOUT=30
CRAWL_DELAY=1.0
MAX_RETRIES=3
MAX_DEPTH=10
MAX_PAGES=5000
RESPECT_ROBOTS_TXT=True
USER_AGENT="AI Categorizer Crawler Bot 1.0"

# Playwright
PLAYWRIGHT_HEADLESS=True
PLAYWRIGHT_TIMEOUT=30000

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=500
LLM_TEMPERATURE=0.1
LLM_BUDGET_LIMIT_USD=1.5

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_BATCH_SIZE=50

# Classification
EMBEDDING_SIMILARITY_THRESHOLD=0.85
DETERMINISTIC_CONFIDENCE_THRESHOLD=0.90
